{
  "appId": "com.salvallantas.inventario",
  "appName": "Salvallanta",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.googleapis.com",
      "*.google.com",
      "script.google.com",
      "*.googleusercontent.com",
      "cdn.tailwindcss.com",
      "fonts.googleapis.com",
      "fonts.gstatic.com",
      "unpkg.com"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#091426",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#091426"
    },
    "BluetoothLe": {
      "displayStrings": {
        "scanning": "Buscando impresoras...",
        "cancel": "Cancelar",
        "availableDevices": "Impresoras disponibles",
        "noDeviceFound": "No se encontraron impresoras"
      }
    }
  }
}
